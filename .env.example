# Copia este archivo a .env.local y rellena con los valores de
# Firebase Console → Project settings → Your apps → SDK setup and configuration.
# No subas .env.local a git (ya está en .gitignore).

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Solo servidor (API con Firebase Admin). En local: ruta al JSON o variable:
# FIREBASE_SERVICE_ACCOUNT_PATH=./ruta/al-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Vercel / App Hosting: define FIREBASE_SERVICE_ACCOUNT_JSON en el panel de variables de entorno.
